{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Uninvited",
  "version": "0.1.0",
  "identifier": "com.xaghoul-games.uninvited",
  "build": {
    "beforeDevCommand": "npm --prefix web run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix web run build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Uninvited",
        "width": 1024,
        "height": 760,
        "minWidth": 800,
        "minHeight": 600,
        "backgroundColor": "#160a26"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {}
  }
}
